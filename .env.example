# Casino Bot — Environment Variables
# Copy this file to .env and fill in your values. Never commit .env.

# ── Discord ──────────────────────────────────────────────────────────────────
# Get this from https://discord.com/developers/applications → your app → Bot → Reset Token
DISCORD_TOKEN=your_discord_bot_token_here

# Comma-separated list of channel IDs where the bot is allowed to respond
ALLOWED_CHANNEL_IDS=123456789012345678,987654321098765432

# Discord user ID of the server admin (has access to admin commands)
ADMIN_USER_ID=your_discord_user_id_here

# Optional: a secondary trusted user ID
LIAM_USER_ID=

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Full connection string (takes priority over individual vars below)
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/casinobot_db

# Individual connection variables (used if DATABASE_URL is not set)
DB_USER=postgres
DB_PASSWORD=yourpassword
DB_HOST=localhost
DB_PORT=5432
DB_NAME=casinobot_db
